    {
      "id": "ms-1",
      "code": "MS-1",
      "type": "national_anthem",
      "title": {
        "ar": "النشيد الوطني اللبناني",
        "en": "Lebanese National Anthem"
      },
      "lyrics": {
        "ar": "كلنا للوطن للعلى للعلم\nملء عين الزمن سيفنا والقلم\nسهلنا والجبل منبت للرجال\nقولنا والعمل في سبيل الكمال\n\nكلنا للوطن للعلى للعلم\nكلنا للوطن\n\nشيخنا والفتى عند صوت الوطن\nأسد غاب متى ساورتنا الفتن\nشرقنا قلبه أبداً لبنان\nصانه ربه لمدى الأزمان\n\nكلنا للوطن للعلى للعلم\nكلنا للوطن\n\nبحره بره درة الشرقين\nرفده بره مالئ القطبين\nاسمه عزه منذ كان الجدود\nمجده أرزه رمزه للخلود\n\nكلنا للوطن للعلى للعلم\nكلنا للوطن",
        "en": null
      },
      "stageIds": ["all"],
      "tags": ["official", "national", "lebanon"],
